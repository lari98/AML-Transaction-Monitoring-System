# =============================================================================
# AML Transaction Monitoring System - Environment Configuration
# UBS/SIX Group Grade | Swiss & German Banking Compliance
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=production
APP_NAME="AML Transaction Monitoring System"
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
DEFAULT_LANGUAGE=de   # de | en

# ── Security & Auth ──────────────────────────────────────────────────────────
SECRET_KEY=<replace-with-256-bit-random-key>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12
API_KEY_HEADER=X-API-Key
ALLOWED_HOSTS=["localhost","aml.bank.internal","aml.bank.de"]
CORS_ORIGINS=["https://aml.bank.internal","https://dashboard.bank.de"]

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aml_user:CHANGE_ME@db:5432/aml_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=CHANGE_ME

# ── Azure ────────────────────────────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_TENANT_ID=<your-tenant-id>
AZURE_CLIENT_ID=<your-client-id>
AZURE_CLIENT_SECRET=<your-client-secret>
AZURE_STORAGE_ACCOUNT=amltxnmonitoring
AZURE_STORAGE_KEY=<your-storage-key>
AZURE_BLOB_CONTAINER=aml-transactions
AZURE_KEY_VAULT_URL=https://aml-kv.vault.azure.net/
AZURE_MONITOR_WORKSPACE_ID=<your-workspace-id>

# ── Databricks ───────────────────────────────────────────────────────────────
DATABRICKS_HOST=https://<your-workspace>.azuredatabricks.net
DATABRICKS_TOKEN=<your-pat-token>
DATABRICKS_CLUSTER_ID=<your-cluster-id>
DATABRICKS_CATALOG=aml_catalog
DATABRICKS_SCHEMA=transactions
MLFLOW_TRACKING_URI=https://<your-workspace>.azuredatabricks.net/mlflow

# ── Kafka / Streaming ────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_TRANSACTIONS=aml.transactions.raw
KAFKA_TOPIC_ALERTS=aml.alerts.realtime
KAFKA_TOPIC_SCORED=aml.transactions.scored
KAFKA_CONSUMER_GROUP=aml-monitoring-group
KAFKA_SCHEMA_REGISTRY_URL=http://schema-registry:8081

# ── ML Models ────────────────────────────────────────────────────────────────
MODEL_REGISTRY_URI=mlflow://aml-model-registry
ANOMALY_MODEL_NAME=aml_isolation_forest
CLUSTER_MODEL_NAME=aml_dbscan
RISK_MODEL_NAME=aml_risk_scorer
MODEL_STAGE=Production
ANOMALY_THRESHOLD=0.65
RISK_HIGH_THRESHOLD=0.80
RISK_MEDIUM_THRESHOLD=0.50
SHAP_EXPLAIN_TOP_N=10

# ── Monitoring ───────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
ALERT_WEBHOOK_URL=https://hooks.bank.internal/aml-alerts
PAGERDUTY_API_KEY=<your-pagerduty-key>
SENTRY_DSN=<your-sentry-dsn>

# ── GDPR/DSGVO ───────────────────────────────────────────────────────────────
PII_ENCRYPTION_KEY=<32-byte-fernet-key>
DATA_RETENTION_DAYS=365
AUDIT_LOG_RETENTION_DAYS=2555   # 7 years (Swiss banking law)
GDPR_DELETE_DELAY_HOURS=24
MASK_PII_IN_LOGS=true
ANONYMIZE_EXPORT=true

# ── Power BI ─────────────────────────────────────────────────────────────────
POWERBI_WORKSPACE_ID=<your-workspace-id>
POWERBI_DATASET_ID=<your-dataset-id>
POWERBI_TENANT_ID=<your-tenant-id>
POWERBI_CLIENT_ID=<your-client-id>
POWERBI_CLIENT_SECRET=<your-client-secret>

# ── Email Alerts ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.bank.internal
SMTP_PORT=587
SMTP_USER=aml-alerts@bank.de
SMTP_PASSWORD=CHANGE_ME
ALERT_EMAIL_FROM=aml-alerts@bank.de
ALERT_EMAIL_TO=compliance@bank.de,aml-team@bank.de
